local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

local MAX_TELEPORT_ATTEMPTS = 5
local TELEPORT_KEY = "ServerHopCount_" .. game.PlaceId

local function GetTeleportCount()
    local count = 0
    pcall(function()
        local saved = LocalPlayer:WaitForChild("PlayerGui"):FindFirstChild(TELEPORT_KEY)
        if saved then
            count = tonumber(saved.Value) or 0
        end
    end)

    if count == 0 then
        pcall(function()
            if _G[TELEPORT_KEY] then
                count = _G[TELEPORT_KEY]
            end
        end)
    end

    return count
end

local function SetTeleportCount(count)
    _G[TELEPORT_KEY] = count
end

local function TeleportToNewServer()
    local success = false

    pcall(function()
        local Net = require(ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Net"))
        Net:RemoteEvent("TeleportService/Reconnect"):FireServer()
        success = true
    end)

    if not success then
        pcall(function()
            for _, child in ipairs(ReplicatedStorage.Packages.Net:GetDescendants()) do
                if child:IsA("RemoteEvent") and child.Name:find("TeleportService") and child.Name:find("Reconnect") then
                    child:FireServer()
                    success = true
                    break
                end
            end
        end)
    end

    if not success then
        pcall(function()
            TeleportService:Teleport(game.PlaceId, LocalPlayer)
        end)
    end
end

